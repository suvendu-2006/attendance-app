{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "test": "node test_integration.js",
    "migrate": "node migrate.js",
    "migrate:all": "psql \"$DATABASE_URL\" -f schema.sql && node migrate.js && psql \"$DATABASE_URL\" -f migrations_fixes.sql && psql \"$DATABASE_URL\" -f migrations_remaining.sql && psql \"$DATABASE_URL\" -f migrations_drop_old_nonce_constraints.sql",
    "seed": "node seed.js"
  },
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "^1.4.1",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "pg": "^8.11.3"
  }
}
